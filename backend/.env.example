# Copy to .env for local dev.
# Postgres URL, e.g. postgresql+psycopg://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=
# MUST be a long random value in production (openssl rand -hex 32)
JWT_SECRET=dev-insecure-change-me
# Comma-separated allowed origins. Add your Vercel URL in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:3100
ENVIRONMENT=development

# --- Cloudflare R2 (optional locally) ---
# When unset, uploads fall back to local disk under LOCAL_STORAGE_DIR and the
# API serves them itself (dev only - configure R2 before production).
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Base URL this API is reachable at (used to build local-dev upload URLs)
API_PUBLIC_URL=http://localhost:8000
LOCAL_STORAGE_DIR=.tmp/storage
